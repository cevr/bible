{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "plugins": ["typescript", "import", "node"],
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-extra-non-null-assertion": "error",
    "typescript/no-non-null-asserted-optional-chain": "error",
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "separate-type-imports" }
    ],
    "import/no-duplicates": "error",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css", "**/*.scss"] }],
    "node/no-process-env": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-underscore-dangle": "off",
    "no-shadow": "off",
    "no-nested-ternary": "off",
    "complexity": ["error", 50],
    "typescript/consistent-return": "off"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/*.d.ts",
    "**/scripts/**",
    "**/bin/**",
    "**/outputs/**/_raw/**"
  ],
  "overrides": [
    {
      "files": ["**/tests/**", "**/test/**", "**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "typescript/no-non-null-assertion": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "node/no-process-env": "off"
      }
    },
    {
      "files": [
        "**/scripts/**",
        "**/packages/core/src/sync/**",
        "**/packages/cli/src/main.ts",
        "**/packages/cli/src/instrumentation/**",
        "**/packages/cli/src/services/logger.ts",
        "**/packages/cli/src/services/model.ts",
        "**/packages/cli/src/lib/paths.ts",
        "**/packages/cli/src/tui/themes/**",
        "**/packages/web/server/main.ts",
        "**/packages/web/e2e/**",
        "**/packages/core/src/egw/auth.ts",
        "**/packages/core/src/egw/client.ts",
        "**/packages/core/src/egw-db/book-database.ts",
        "**/packages/core/src/bible-db/bible-database.ts",
        "**/packages/core/src/hymnal/database.ts",
        "**/packages/core/src/gemini/client.ts"
      ],
      "rules": {
        "node/no-process-env": "off"
      }
    },
    {
      "files": [
        "**/packages/core/src/gemini/client.ts",
        "**/packages/core/src/egw/client.ts",
        "**/packages/core/src/egw-db/book-database.ts",
        "**/packages/core/src/bible-db/bible-database.ts",
        "**/packages/core/src/hymnal/**",
        "**/packages/core/src/cache/**",
        "**/packages/core/src/ai/**",
        "**/packages/core/src/egw-gemini/**",
        "**/packages/core/src/structural-analysis/**",
        "**/packages/core/src/sync/**",
        "**/packages/core/src/utils/match.ts",
        "**/packages/web/src/workers/**",
        "**/packages/web/src/lib/cached-app.ts",
        "**/packages/web/src/data/**",
        "**/packages/web/src/providers/**",
        "**/packages/web/src/components/**",
        "**/packages/web/src/routes/**",
        "**/packages/test-utils/**",
        "**/packages/cli/src/lib/**",
        "**/packages/cli/src/data/**",
        "**/packages/cli/src/services/**",
        "**/packages/cli/src/commands/**",
        "**/packages/cli/src/tui/**"
      ],
      "rules": {
        "typescript/no-unsafe-type-assertion": "off"
      }
    },
    {
      "files": ["**/packages/web/**/*.tsx", "**/packages/web/**/*.ts"],
      "rules": {
        "typescript/no-floating-promises": "off",
        "typescript/unbound-method": "off"
      }
    },
    {
      "files": [
        "**/packages/core/src/egw-reader/**",
        "**/packages/core/src/app/**",
        "**/packages/cli/src/tui/context/**"
      ],
      "rules": {
        "typescript/no-misused-spread": "off"
      }
    }
  ]
}
