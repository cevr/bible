# EGW Writings API credentials.
# Request OAuth credentials at https://cpanel.egwwritings.org/
#
# These get baked into the renderer bundle at build time via Bun's `define`
# (see scripts/build-main.ts and vite.config.ts). Keep the renderer-bundle
# secrets in sync with packages/core/.env if you're sharing one account between
# the CLI and the desktop app.
EGW_CLIENT_ID=
EGW_CLIENT_SECRET=

# Optional overrides — defaults shown.
# EGW_API_BASE_URL=https://a.egwwritings.org
# EGW_AUTH_BASE_URL=https://cpanel.egwwritings.org
# EGW_SCOPE=writings search studycenter subscriptions user_info
# EGW_USER_AGENT=EGW-Desktop/0.1
