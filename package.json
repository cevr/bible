{
  "name": "bible-tools",
  "version": "1.0.0",
  "private": true,
  "description": "bible tools",
  "license": "MIT",
  "author": "cristian ramos <seeve.c@gmail.com>",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "turbo run test",
    "gate": "concurrently -n turbo,lint,fmt -c blue,yellow,magenta \"turbo run typecheck test build\" \"bun run lint:fix\" \"bun run fmt\"",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "prepare": "effect-language-service patch && lefthook install"
  },
  "devDependencies": {
    "@effect/language-service": "^0.82.0",
    "concurrently": "^9.2.1",
    "effect-bun-test": "^0.2.1",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "turbo": "^2.8.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "@effect/language-service": "0.82.0",
    "@effect/platform-bun": "4.0.0-beta.38",
    "@types/bun": "1.3.9",
    "ai": "6.0.84",
    "typescript": "5.9.3",
    "effect": "4.0.0-beta.38"
  }
}
