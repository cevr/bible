{
  "name": "bible",
  "version": "1.0.0",
  "private": true,
  "description": "bible",
  "license": "MIT",
  "author": "cristian ramos <seeve.c@gmail.com>",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "turbo run test",
    "gate": "concurrently -n type,style,build -c blue,yellow,cyan \"bun run typecheck\" \"bun run lint && bun run fmt\" \"bun run build\" && bun run test",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "prepare": "lefthook install && effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/tsgo": "0.5.2",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "concurrently": "^9.2.1",
    "effect-bun-test": "0.3.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "effect": "4.0.0-beta.64"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.64",
    "@types/bun": "1.3.13",
    "effect": "4.0.0-beta.64",
    "effect-bun-test": "0.3.0"
  }
}
