{
  "name": "bible",
  "version": "1.0.0",
  "private": true,
  "description": "bible",
  "license": "MIT",
  "author": "cristian ramos <seeve.c@gmail.com>",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "turbo run test",
    "test:perf": "turbo run test:perf --concurrency=1",
    "gate": "concurrently -n style,turbo -c yellow,cyan \"bun run lint && bun run fmt\" \"turbo run gate\" && bun run test:perf",
    "gate:fix": "bun run lint:fix && bun run fmt && bun run gate",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "prepare": "(test -d .git && lefthook install || true) && effect-tsgo patch"
  },
  "dependencies": {
    "@solid-primitives/refs": "^1.1.3"
  },
  "devDependencies": {
    "@effect/tsgo": "0.5.2",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "concurrently": "^9.2.1",
    "effect-bun-test": "0.3.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "effect": "4.0.0-beta.68"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.68",
    "@effect/sql-sqlite-bun": "4.0.0-beta.68",
    "@effect/sql-sqlite-node": "4.0.0-beta.68",
    "@types/bun": "1.3.13",
    "effect": "4.0.0-beta.68",
    "effect-bun-test": "0.3.0"
  }
}
