---
import { getCollection } from "astro:content";
import Site from "../../layouts/Site.astro";
import { getSeriesMeta } from "../../lib/content.ts";

const meta = await getSeriesMeta("bohr-vs-millers-rules");
const chapters = (await getCollection("seriesChapters")).map((e) => e.data);

// Preserve canonical order from the extractor (Dan 11 first, then Rev 1-22).
const order = ["dan-11", ...Array.from({ length: 22 }, (_, i) => `rev-${i + 1}`)];
const ordered = order
  .map((slug) => chapters.find((c) => c.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
---

<Site
  title={`${meta.title} — Bible studies`}
  description={meta.lede}
>
  <main class="shell">
    <header class="masthead">
      <p class="eyebrow">{meta.eyebrow}</p>
      <h1>{meta.title} — <em>{meta.subtitle}</em></h1>
    </header>

    <ol class="chapter-list">
      {ordered.map((c) => (
        <li class="chapter-row">
          <a href={`./${c.slug}/`} class="chapter-link">
            <span class="ref">{c.ref}</span>
            <span class="title">{c.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </main>
</Site>

<style>
  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0 0 6rem;
    border-top: 1px solid var(--rule-soft);
  }
  .chapter-row {
    border-bottom: 1px solid var(--rule-soft);
  }
  .chapter-link {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 1.25rem;
    align-items: baseline;
    padding: 1rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s, background 0.15s;
  }
  .chapter-link:hover,
  .chapter-link:focus-visible {
    outline: none;
    background: color-mix(in srgb, var(--paper-tint) 40%, var(--paper));
  }
  .chapter-link:hover .ref { color: var(--oxblood); }
  .ref {
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.15s;
  }
  .title {
    font-family: var(--display);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--ink);
  }
</style>
