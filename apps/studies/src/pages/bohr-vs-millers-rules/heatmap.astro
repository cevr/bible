---
import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import { marked } from "marked";
import Site from "../../layouts/Site.astro";
import { getSeriesMeta } from "../../lib/content.ts";

const meta = await getSeriesMeta("bohr-vs-millers-rules");

const __dirname = dirname(fileURLToPath(import.meta.url));
const APP_ROOT = resolve(__dirname, "..", "..", "..");
const heatmapPath = resolve(
  APP_ROOT,
  "content/series/bohr-vs-millers-rules/heatmap.md",
);
const md = readFileSync(heatmapPath, "utf8");
const html = marked.parse(md, { gfm: true });
---

<Site
  title={`Heatmap — ${meta.title}`}
  description={`Visual heatmap of Miller-rule violation density across the audit.`}
  seriesSlug={meta.slug}
  currentNav="heatmap"
>
  <main class="shell">
    <header class="masthead">
      <p class="eyebrow">{meta.eyebrow} · Heatmap</p>
      <h1>Violation <em>density</em></h1>
      <p class="lede">
        Where the Miller-rule divergences cluster across the 280-verse
        corpus — at a glance.
      </p>
    </header>

    <main class="content" set:html={html} />
  </main>
</Site>
