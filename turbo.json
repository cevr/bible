{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "electron/**/*.ts",
        "scripts/**/*.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "electron/**/*.ts",
        "scripts/**/*.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "test/**/*.ts",
        "test/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "package.json"
      ],
      "outputs": [],
      "cache": false
    },
    "test:perf": {
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/perf/**/*.ts", "package.json"],
      "outputs": [],
      "cache": false
    },
    "lint": {
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "gate": {
      "dependsOn": ["typecheck", "build", "test"],
      "outputs": []
    }
  }
}
